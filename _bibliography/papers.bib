	doi = {10.1145/2463372.2463443},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84883093341&doi=10.1145%2f2463372.2463443&partnerID=40&md5=e4236ab311e6dfe880e5d7af94d244a0},
	affiliations = {Dept. TC2, Polytechnic School, University of Extremadura, Cáceres, Spain; School of Computer Science and Electronic Engineering, University of Essex, Colchester, United Kingdom},
	abstract = {Optical networks have attracted much more attention in the last decades due to its huge bandwidth (Tbps). The Wavelength Division Multiplexing (WDM) is a technology that aims to make the most of this networks by dividing each single fiber link into several wavelengths of light (λ) or channels. Each channel operates in the range of Gbps; unfortunately, the requirements of the vast majority of current traffic connection requests are a few Mbps, causing a waste of bandwidth at each channel. We can solve this drawback by equipping each optical node with an access station for multiplexing or grooming several low-speed requests onto one single high-speed channel. This problem of grooming low-speed requests is known in the literature as the Traffic Grooming problem. In this work, we formulate the Traffic Grooming problem as a Multiobjective Optimization Problem, optimizing simultaneously the total throughput, the number of transceivers used, and the average propagation delay. We propose the use of the Multiobjective Evolutionary Algorithm based on Decomposition (MOEA/D). The experiments are conducted on three optical network topologies and diverse scenarios. The results report that the MOEA/D algorithm works more efficiently than other multiobjective approaches and other single-objective heuristics published in the literature. Copyright © 2013 ACM.},
	author_keywords = {MOEA/D; Multiobjective optimization; Traffic Grooming; WDM optical networks},
