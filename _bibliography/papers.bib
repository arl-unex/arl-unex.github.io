	keywords = {Bandwidth; Evolutionary algorithms; Fiber optic networks; Multiobjective optimization; Multiplexing equipment; Optical fibers; Topology; Wavelength; Wavelength division multiplexing; Bandwidth waste; Differential Evolution; Electronic device; Multi objective; Multi objective evolutionary algorithms; Routing and wavelength assignment; Routing and wavelength assignment problems; Source-destination pairs; Technology-based; WDM networks; Problem solving},
	correspondence_address = {Á. Rubio-Largo; Department of Technologies of Computers and Communications, University of Extremadura, Cáceres 10071, Spain; email: arl@unex.es},
	isbn = {978-142446910-9},
