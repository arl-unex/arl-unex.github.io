	source = {Scopus},
	note = {Cited by: 2; Conference name: 14th IEEE International Conference on Trust, Security and Privacy in Computing and Communications, TrustCom 2015; Conference date: 20 August 2015 through 22 August 2015; Conference code: 118386}
}

